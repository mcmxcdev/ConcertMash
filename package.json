{
  "name": "concertmash",
  "description": "Easily generate a playlist for your upcoming concerts based on selected artists!",
  "version": "1.0.0",
  "author": "MCMXC",
  "license": "MIT",
  "homepage": "https://github.com/mcmxcdev/ConcertMash",
  "scripts": {
    "clean": "rm -rf .svelte-kit && rm -rf build",
    "dev": "vite dev",
    "validate": "svelte-kit sync && svelte-check",
    "format": "prettier --write --cache src/**/*{.svelte,.ts}",
    "lint": "eslint src",
    "lint:fix": "pnpm lint --fix",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.65.2",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "autoprefixer": "^10.5.0",
    "axios": "^1.18.0",
    "cssnano": "^8.0.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-svelte": "^3.19.0",
    "eslint-plugin-unicorn": "^67.0.0",
    "filepond": "^4.32.12",
    "filepond-plugin-file-encode": "^2.1.14",
    "filepond-plugin-file-validate-size": "^2.2.8",
    "filepond-plugin-file-validate-type": "^1.2.9",
    "filepond-plugin-image-exif-orientation": "^1.0.11",
    "filepond-plugin-image-preview": "^4.6.12",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "p-limit": "^7.3.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "spotify-web-api-js": "^1.5.2",
    "svelte": "^5.56.3",
    "svelte-awesome": "^3.3.5",
    "svelte-check": "^4.6.0",
    "svelte-filepond": "^0.2.2",
    "svelte-forms-lib": "^2.0.1",
    "svelte-select": "^5.8.3",
    "svelte-sonner": "^1.1.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "yup": "^1.7.1"
  },
  "packageManager": "pnpm@11.8.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  }
}
